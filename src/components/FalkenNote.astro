---
interface Props {
  title?: string;
}
const { title = 'Note de Falken' } = Astro.props;
---

<aside class="falken-note">
  <div class="falken-header">
    <span class="falken-icon">&#9670;</span>
    <span class="falken-title">{title}</span>
  </div>
  <div class="falken-content">
    <slot />
  </div>
</aside>

<style>
  .falken-note {
    margin: 2.5rem 0;
    border: 1px solid rgba(255, 176, 0, 0.25);
    border-left: 3px solid #ffb000;
    border-radius: 0 8px 8px 0;
    background: rgba(255, 176, 0, 0.04);
    overflow: hidden;
  }

  .falken-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    background: rgba(255, 176, 0, 0.08);
    border-bottom: 1px solid rgba(255, 176, 0, 0.12);
  }

  .falken-icon {
    color: #ffb000;
    font-size: 0.7rem;
  }

  .falken-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #ffb000;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .falken-content {
    padding: 1rem 1.25rem;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-text-muted, #94a3b8);
  }

  .falken-content :global(p) {
    margin-bottom: 0.75rem;
  }

  .falken-content :global(p:last-child) {
    margin-bottom: 0;
  }

  .falken-content :global(strong) {
    color: var(--color-text, #e2e8f0);
  }

  .falken-content :global(em) {
    color: #ffb000;
    font-style: italic;
  }
</style>
