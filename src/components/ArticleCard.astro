---
interface Props {
  title: string;
  date: Date;
  tags: string[];
  summary: string;
  slug: string;
  readingTime: number;
  cover?: string;
}

const { title, date, tags, summary, slug, readingTime, cover } = Astro.props;
const ASSETS_BASE = 'https://assets.pixelium.win';

const formatted = date.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`/${slug}/`} class="card reveal">
  {cover && (
    <div class="card-cover">
      <img src={`${ASSETS_BASE}/${cover}`} alt="" loading="lazy" />
    </div>
  )}
  <div class="card-body">
    <div class="card-meta">
      <time datetime={date.toISOString().split('T')[0]}>{formatted}</time>
      <span class="sep">&middot;</span>
      <span class="reading-time">{readingTime} min</span>
    </div>
    <h2 class="card-title">{title}</h2>
    <p class="card-summary">{summary}</p>
    <div class="card-bottom">
      <div class="card-tags">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
      <span class="card-read">
        Lire <span class="arrow">&rarr;</span>
      </span>
    </div>
  </div>
</a>

<style>
  .card {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: 0;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius);
    color: var(--color-text);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .card:not(:has(.card-cover)) {
    grid-template-columns: 1fr;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-accent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .card:hover {
    color: var(--color-text);
    border-color: var(--color-border);
    transform: translateX(2px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(56, 189, 248, 0.05);
  }

  .card:hover::before { opacity: 1; }

  .card-cover {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    border-right: 1px solid var(--color-border-subtle);
  }

  .card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    transition: transform 0.4s ease;
  }

  .card:hover .card-cover img { transform: scale(1.03); }

  .card-body {
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    min-height: 8rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-faint);
  }

  .card-meta time { color: var(--color-text-muted); }
  .reading-time { color: var(--color-accent); opacity: 0.7; }

  .card-title {
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .card:hover .card-title { color: var(--color-accent-hover); }

  .card-summary {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    gap: 1rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    padding: 0.12rem 0.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: 3px;
    color: var(--color-text-faint);
    letter-spacing: 0.02em;
  }

  .card:hover .tag { border-color: var(--color-border); }

  .card-read {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(-0.5rem);
    transition: all 0.3s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .card:hover .card-read { opacity: 1; transform: none; }
  .arrow { transition: transform 0.2s; display: inline-block; }
  .card:hover .arrow { transform: translateX(3px); }

  @media (max-width: 700px) {
    .card {
      grid-template-columns: 1fr;
    }

    .card-cover {
      height: 10rem;
      border-right: none;
      border-bottom: 1px solid var(--color-border-subtle);
    }

    .card-body {
      padding: 1.25rem;
    }

    .card-read { opacity: 1; transform: none; }
  }
</style>
