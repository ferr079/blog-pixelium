---
interface Props {
  prev?: { title: string; slug: string } | null;
  next?: { title: string; slug: string } | null;
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav class="prev-next" aria-label="Navigation entre articles">
    <div class="pn-grid">
      {prev ? (
        <a href={`/${prev.slug}/`} class="pn-card pn-prev">
          <span class="pn-label"><span class="pn-arrow">&larr;</span> Precedent</span>
          <span class="pn-title">{prev.title}</span>
        </a>
      ) : <div />}
      {next ? (
        <a href={`/${next.slug}/`} class="pn-card pn-next">
          <span class="pn-label">Suivant <span class="pn-arrow">&rarr;</span></span>
          <span class="pn-title">{next.title}</span>
        </a>
      ) : <div />}
    </div>
  </nav>
)}

<style>
  .prev-next {
    max-width: var(--content-width);
    padding: 0 0 2rem;
  }

  .pn-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .pn-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.25rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius);
    color: var(--color-text);
    transition: all 0.2s;
  }

  .pn-card:hover {
    border-color: var(--color-border);
    color: var(--color-text);
  }

  .pn-card:hover .pn-title { color: var(--color-accent); }

  .pn-next { text-align: right; }

  .pn-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-faint);
  }

  .pn-arrow {
    display: inline-block;
    transition: transform 0.2s;
  }

  .pn-prev:hover .pn-arrow { transform: translateX(-3px); }
  .pn-next:hover .pn-arrow { transform: translateX(3px); }

  .pn-title {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.35;
    transition: color 0.2s;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .pn-grid { grid-template-columns: 1fr; }
    .pn-next { text-align: left; }
  }
</style>
